generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Platforms ────────────────────────────────────────

model Platform {
  id       Int     @id @default(autoincrement())
  slug     String  @unique // 'polymarket', 'kalshi'
  name     String
  apiBase  String? @map("api_base")
  feeModel Json?   @map("fee_model")

  markets         Market[]
  accuracyRecords AccuracyRecord[]
  whaleTrades     WhaleTrade[]

  @@map("platforms")
}

// ── Markets ──────────────────────────────────────────

model Market {
  id             Int           @id @default(autoincrement())
  platformId     Int           @map("platform_id")
  externalId     String        @map("external_id")
  title          String
  description    String?
  category       String?
  status         String        @default("active") // active, resolved, cancelled, closed
  resolutionDate DateTime?     @map("resolution_date") @db.Timestamptz
  resolvedAt     DateTime?     @map("resolved_at") @db.Timestamptz
  outcome        String?       // yes, no
  url            String?
  yesPrice       Decimal?      @map("yes_price") @db.Decimal(6, 4)
  noPrice        Decimal?      @map("no_price") @db.Decimal(6, 4)
  volume24h      Decimal?      @map("volume_24h") @db.Decimal(18, 2)
  liquidity      Decimal?      @db.Decimal(18, 2)
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  platform        Platform        @relation(fields: [platformId], references: [id])
  priceSnapshots  PriceSnapshot[]
  accuracyRecords AccuracyRecord[]
  whaleTrades     WhaleTrade[]
  matchesAsA      MarketMatch[]   @relation("MarketA")
  matchesAsB      MarketMatch[]   @relation("MarketB")

  @@unique([platformId, externalId])
  @@index([platformId, status])
  @@index([category])
  @@index([status])
  @@map("markets")
}

// ── Market Matches (cross-platform) ─────────────────

model MarketMatch {
  id          Int      @id @default(autoincrement())
  marketAId   Int      @map("market_a_id")
  marketBId   Int      @map("market_b_id")
  confidence  Float
  matchMethod String   @map("match_method") // auto_structured, auto_fuzzy, manual
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  marketA          Market           @relation("MarketA", fields: [marketAId], references: [id])
  marketB          Market           @relation("MarketB", fields: [marketBId], references: [id])
  arbOpportunities ArbOpportunity[]

  @@unique([marketAId, marketBId])
  @@index([confidence(sort: Desc)])
  @@map("market_matches")
}

// ── Price Snapshots (time-series) ────────────────────

model PriceSnapshot {
  id         BigInt   @id @default(autoincrement())
  marketId   Int      @map("market_id")
  yesPrice   Decimal? @map("yes_price") @db.Decimal(6, 4)
  noPrice    Decimal? @map("no_price") @db.Decimal(6, 4)
  volume24h  Decimal? @map("volume_24h") @db.Decimal(18, 2)
  liquidity  Decimal? @db.Decimal(18, 2)
  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  market Market @relation(fields: [marketId], references: [id])

  @@index([marketId, recordedAt(sort: Desc)])
  @@map("price_snapshots")
}

// ── Arb Opportunities ───────────────────────────────

model ArbOpportunity {
  id             Int       @id @default(autoincrement())
  matchId        Int       @map("match_id")
  spreadRaw      Decimal?  @map("spread_raw") @db.Decimal(6, 4)
  spreadAdjusted Decimal?  @map("spread_adjusted") @db.Decimal(6, 4)
  buyPlatform    String    @map("buy_platform")
  buyPrice       Decimal?  @map("buy_price") @db.Decimal(6, 4)
  sellPrice      Decimal?  @map("sell_price") @db.Decimal(6, 4)
  volumeMin      Decimal?  @map("volume_min") @db.Decimal(18, 2)
  detectedAt     DateTime  @default(now()) @map("detected_at") @db.Timestamptz
  closedAt       DateTime? @map("closed_at") @db.Timestamptz
  profitable     Boolean?

  match MarketMatch @relation(fields: [matchId], references: [id])

  @@index([spreadAdjusted(sort: Desc)])
  @@map("arb_opportunities")
}

// ── Accuracy Records ────────────────────────────────

model AccuracyRecord {
  id         Int       @id @default(autoincrement())
  marketId   Int       @map("market_id")
  platformId Int       @map("platform_id")
  category   String?
  finalPrice Decimal?  @map("final_price") @db.Decimal(6, 4)
  outcome    Decimal?  @db.Decimal(1, 0) // 1 = yes, 0 = no
  brierScore Decimal?  @map("brier_score") @db.Decimal(6, 4)
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz

  market   Market   @relation(fields: [marketId], references: [id])
  platform Platform @relation(fields: [platformId], references: [id])

  @@unique([marketId, platformId])
  @@index([platformId, category])
  @@map("accuracy_records")
}

// ── Whale Trades ────────────────────────────────────

model WhaleTrade {
  id            Int      @id @default(autoincrement())
  marketId      Int      @map("market_id")
  traderAddress String?  @map("trader_address")
  sizeUsd       Decimal  @map("size_usd") @db.Decimal(18, 2)
  side          String   // yes, no
  price         Decimal? @db.Decimal(6, 4)
  platformId    Int      @map("platform_id")
  detectedAt    DateTime @default(now()) @map("detected_at") @db.Timestamptz

  market   Market   @relation(fields: [marketId], references: [id])
  platform Platform @relation(fields: [platformId], references: [id])

  @@index([detectedAt(sort: Desc)])
  @@index([sizeUsd(sort: Desc)])
  @@map("whale_trades")
}

// ── Users ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified") @db.Timestamptz
  image         String?
  walletAddress String?   @map("wallet_address")
  stripeCustomerId String? @map("stripe_customer_id")
  tier          String    @default("free") // free, pro, enterprise
  apiKey        String?   @unique @map("api_key")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  accounts Account[]
  sessions Session[]
  alerts   Alert[]

  @@map("users")
}

// ── NextAuth Tables ─────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── User Alerts ─────────────────────────────────────

model Alert {
  id            Int      @id @default(autoincrement())
  userId        String   @map("user_id")
  type          String   // spread, volume, whale, new_market
  config        Json?
  channel       String   // email, telegram, webhook
  channelConfig Json?    @map("channel_config")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alerts")
}
