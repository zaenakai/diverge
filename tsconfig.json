{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "paths": {
      "@diverge/core/*": ["./packages/core/src/*"],
      "@diverge/functions/*": ["./packages/functions/src/*"]
    }
  },
  "exclude": ["node_modules", ".sst", "dist"]
}
