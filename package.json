{
  "name": "diverge",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sst dev --stage dev",
    "dev:web": "cd packages/web && next dev",
    "build": "cd packages/web && next build",
    "deploy": "sst deploy --stage production",
    "deploy:dev": "sst deploy --stage dev",
    "remove": "sst remove",
    "remove:dev": "sst remove --stage dev",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "collect:markets": "tsx packages/functions/src/collectors/markets.ts",
    "collect:prices": "tsx packages/functions/src/collectors/prices.ts",
    "collect:matcher": "tsx packages/functions/src/collectors/matcher.ts",
    "collect:arbs": "tsx packages/functions/src/collectors/arbs.ts",
    "collect:accuracy": "tsx packages/functions/src/collectors/accuracy.ts",
    "secrets:set": "sst secret set --stage dev",
    "secrets:list": "sst secret list --stage dev",
    "unlock": "sst unlock --stage dev",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "sst": "^4.1.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.19.0"
  }
}
